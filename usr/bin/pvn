    echo "║  P-O-I-V-O-N - Agente para Termux               ║"
    echo "║  [${AGENT_CHANNEL:-BETA}] v${AGENT_VERSION:-1.2.0-beta}         ║"
    echo "╠══════════════════════════════════════════════════╣"
    echo "║                                                  ║"
    echo "║  Uso: pvn <comando> [argumentos]                 ║"
    echo "║                                                  ║"
    echo "║  Comandos:                                       ║"
    echo "║  (sem args)  Iniciar o agente                     ║"
    echo "║  criar       Criar projeto do zero                ║"
    echo "║  editar      Editar arquivo existente             ║"
    echo "║  corrigir    Corrigir bug                         ║"
