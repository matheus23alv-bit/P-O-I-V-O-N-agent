}

# Status do ambiente
check_status() {
    echo ""
    echo "┌──────────────────────────────────────────────────┐"
    echo "│   •[ P-O-I-V-O-N ]  //\\\\  pensando.....•      │"
    echo "└──────────────────────────────────────────────────┘"
    echo ""
    echo "[STATUS] Verificando ambiente Termux..."
    echo "[STATUS] Canal: ${AGENT_CHANNEL:-Beta} | v${AGENT_VERSION:-1.2.0-beta}"
    echo ""
    
    # Verificar Python
    if command -v python &>/dev/null; then
        echo "[OK] Python: $(python --version 2>&1)"
    else
        echo "[ERRO] Python não instalado. Execute: pkg install python"
    fi
    
    # Verificar Node.js
    if command -v node &>/dev/null; then
        echo "[OK] Node.js: $(node --version)"
    else
        echo "[ERRO] Node.js não instalado. Execute: pkg install nodejs"
    fi
    
    # Verificar Git
    if command -v git &>/dev/null; then
        echo "[OK] Git: $(git --version)"
    else
        echo "[ERRO] Git não instalado. Execute: pkg install git"
    fi
    
    # Verificar Nano
    if command -v nano &>/dev/null; then
        echo "[OK] Nano: disponível"
    else
        echo "[ERRO] Nano não instalado. Execute: pkg install nano"
    fi
    
    # Verificar diretório de trabalho
    if [ -d "$WORK_DIR" ]; then
        echo "[OK] Diretório de trabalho: $WORK_DIR"
        echo "     Projetos: $(find "$WORK_DIR/projects" -maxdepth 1 -type d 2>/dev/null | wc -l) diretórios"
    else
        echo "[ERRO] Diretório de trabalho não existe. Execute: pvn setup"
    fi
    
    # Verificar Firebase
    echo "[INFO] Firebase: ${FIREBASE_ACTIVE:-false}"
    
    echo ""
    echo "─────────────────────────────────────────"
    echo "  PVN S¥STEM | AGENTE POIVON | skill yb POIVON | Beta"
    echo "  ${AGENT_CHANNEL:-branch1} | v${AGENT_VERSION:-1.2.0-beta}"
    echo "─────────────────────────────────────────"
    echo ""
}

# Setup do ambiente completo
do_setup() {
    echo ""
    echo "┌──────────────────────────────────────────────────┐"
    echo "│   •[ P-O-I-V-O-N ]  //\\\\  instalando.....•    │"
    echo "└──────────────────────────────────────────────────┘"
    echo ""
    echo "[SETUP] Configurando ambiente POIVON Termux..."
    echo "[SETUP] Canal: ${AGENT_CHANNEL:-Beta}"
    echo ""
    
    echo "[1/5] Atualizando repositórios..."
    pkg update -y 2>/dev/null
    pkg upgrade -y 2>/dev/null
    
    echo "[2/5] Instalando dependências essenciais..."
    pkg install -y python nodejs git curl wget nano clang 2>/dev/null
    
    echo "[3/5] Instalando pacotes Python..."
    pip install flask requests beautifulsoup4 pillow pygments html5lib colorama watchdog 2>/dev/null
    
    echo "[4/5] Concedendo permissões..."
    termux-setup-storage 2>/dev/null || true
    
    echo "[5/5] Criando estrutura de diretórios..."
    mkdir -p "$WORK_DIR/projects"
    mkdir -p "$WORK_DIR/scripts"
    mkdir -p "$WORK_DIR/data"
    mkdir -p "$WORK_DIR/backups"
    mkdir -p "$WORK_DIR/logs"
    mkdir -p "$WORK_DIR/guides"
    
    echo ""
    echo "╔══════════════════════════════════════════════════╗"
    echo "║   ✓✓✓  [ P-O-I-V-O-N ]  concluído.....•  ✓✓✓   ║"
    echo "║   [${AGENT_CHANNEL:-BETA}] v${AGENT_VERSION:-1.2.0-beta}    ║"
    echo "╚══════════════════════════════════════════════════╝"
    echo ""
    echo "─────────────────────────────────────────"
    echo "  PVN S¥STEM | AGENTE POIVON | skill yb POIVON | Beta"
    echo "  ${AGENT_CHANNEL:-branch1} | v${AGENT_VERSION:-1.2.0-beta}"
    echo "─────────────────────────────────────────"
    echo ""
}

# Iniciar servidor local
do_server() {
    local port="${1:-8080}"
    echo ""
    echo "┌──────────────────────────────────────────────────┐"
    echo "│   •[ P-O-I-V-O-N ]  //\\\\  programando.....•   │"
    echo "└──────────────────────────────────────────────────┘"
    echo ""
    echo "[SERVER] Iniciando servidor local na porta $port..."
    echo "[SERVER] Diretório: $WORK_DIR/projects"
    echo "[SERVER] URL: http://localhost:$port"
    echo ""
    python -m http.server "$port" --directory "$WORK_DIR/projects"
}

# Instalar dependência
do_install() {
    local package="$1"
    if [ -z "$package" ]; then
        echo "[ERRO] Especifique o pacote: pvn install <pacote>"
        return 1
    fi
    
    echo ""
    echo "┌──────────────────────────────────────────────────┐"
    echo "│   •[ P-O-I-V-O-N ]  //\\\\  instalando.....•    │"
    echo "└──────────────────────────────────────────────────┘"
    echo ""
    
    # Detectar tipo de pacote e instalar
    if [[ "$package" == *".deb" ]]; then
        pkg install -y "$package"
    elif [[ "$package" == *"pip:"* ]]; then
        pip install "${package#pip:}"
    elif [[ "$package" == *"npm:"* ]]; then
        npm install -g "${package#npm:}"
    else
        pkg install -y "$package"
    fi
    
    echo "[OK] $package instalado com sucesso."
}

# Criar backup
do_backup() {
    local project="${1:-all}"
    local backup_dir="$WORK_DIR/backups"
    local timestamp=$(date +%Y%m%d_%H%M%S)
    
    echo ""
    echo "┌──────────────────────────────────────────────────┐"
    echo "│   •[ P-O-I-V-O-N ]  //\\\\  pensando.....•      │"
    echo "└──────────────────────────────────────────────────┘"
    echo ""
    echo "[BACKUP] Criando backup..."
    
    mkdir -p "$backup_dir"
    
    if [ "$project" = "all" ]; then
        cp -r "$WORK_DIR/projects" "$backup_dir/projects_$timestamp"
        echo "[OK] Backup completo: $backup_dir/projects_$timestamp"
    else
        cp -r "$WORK_DIR/projects/$project" "$backup_dir/${project}_$timestamp"
        echo "[OK] Backup de $project: $backup_dir/${project}_$timestamp"
    fi
    
    echo ""
    echo "─────────────────────────────────────────"
    echo "  PVN S¥STEM | AGENTE POIVON | skill yb POIVON | Beta"
    echo "  ${AGENT_CHANNEL:-branch1} | v${AGENT_VERSION:-1.2.0-beta}"
    echo "─────────────────────────────────────────"
    echo ""
}

# ─────────────────────────────────────────────────────
# MEMÓRIA ¥00 (PASTA PADRÃO)  —  pvn +mm ¥00 <caminho>
# Version: v1.3.0
# ─────────────────────────────────────────────────────

do_mm_memory() {
    local slot="$1"
    local caminho="$2"

    case "$slot" in
        "¥00"|"￥00") ;;   # half/full-width (teclado Android)
        *)
        echo "[ERRO] Slot de memória inválido: ${slot:-<vazio>}"
        echo "[INFO] Uso: pvn +mm ¥00 <caminho>"
        return 1 ;;
    esac

    if [ -z "$caminho" ]; then
        echo "[ERRO] Caminho ausente."
        echo "[INFO] Uso: pvn +mm ¥00 ~/storage/downloads/"
        return 1
    fi

    if [ -z "${PREFIX:-}" ]; then
        echo "[ERRO] \$PREFIX vazio — ambiente não parece Termux."
        return 1
    fi

    # Aceita apenas: ~/... , $HOME/... , $PREFIX/... (literais)
    # ou caminho já expandido pelo shell para dentro de $HOME/$PREFIX.
    case "$caminho" in
        "~/"*|'$HOME'*|'$PREFIX'*) ;;
        "$HOME"/*) ;;
        "$PREFIX"/*) ;;
        *)
            echo "[ERRO] Caminho rejeitado: $caminho"
            echo "[INFO] Caminhos relativos (ex.: Storage/...) falham no Termux."
            echo "[INFO] Use ~/storage/... (após termux-setup-storage),"
            echo "[INFO] ou um caminho iniciado por \$HOME ou \$PREFIX."
            return 1
            ;;
    esac

    local cfg_dir="$HOME/.config/poivon"
    local cfg_file="$cfg_dir/config"

    mkdir -p "$cfg_dir"

    { [ -f "$cfg_file" ] && grep -v '^PASTA_PADRAO=' "$cfg_file"; echo "PASTA_PADRAO=$caminho"; } > "$cfg_file.tmp" && mv "$cfg_file.tmp" "$cfg_file"

    chmod 600 "$cfg_file"

    echo "✓ memória atualizada"
    echo "¥00 (pasta padrão) = $caminho"
    echo "tudo sem destino explícito vai pra cá."
}

# ─────────────────────────────────────────────────────
# CHAVE DA API  —  pvn chave  (entrada oculta, local)
# Version: v2.0.0
# ─────────────────────────────────────────────────────

do_chave() {
    local cfg="${PVN_CONFIG:-$PREFIX/etc/p-o-i-v-o-n/pvn.conf}"
    if [ ! -f "$cfg" ]; then
        echo "[ERRO] pvn.conf não encontrado em: $cfg"
        echo "[INFO] Rode a instalação primeiro (setup_main.sh / setup_branch1.sh)."
        return 1
    fi
    printf "Cole a chave da API (entrada oculta): "
    local key; IFS= read -rs key; echo ""
    case "$key" in
        sk-ant-*) ;;
        "") echo "[ERRO] Nada recebido."; return 1 ;;
        *)  echo "[ERRO] Formato inesperado (esperado: sk-ant-...)."; return 1 ;;
    esac
    { grep -v '^LLM_API_KEY=' "$cfg"; echo "LLM_API_KEY=\"$key\""; } > "$cfg.tmp" && mv "$cfg.tmp" "$cfg"
    chmod 600 "$cfg"
    echo "✓ chave gravada (600) em: $cfg"
    echo "→ nunca cole a chave em chats, prints ou commits."
}

# ─────────────────────────────────────────────────────
# MAIN
# ─────────────────────────────────────────────────────

PVN_LIBDIR="$(cd "$(dirname "$0")/../lib/p-o-i-v-o-n" 2>/dev/null && pwd)"
[ -n "$PVN_LIBDIR" ] || PVN_LIBDIR="$PREFIX/lib/p-o-i-v-o-n"

case "${1:-}" in
    ""|"")
        splash_screen
        ;;
    "help"|"-h"|"--help")
        show_help
        ;;
    "status")
        check_status
        ;;
    "setup")
        do_setup
        ;;
    "server")
        do_server "${2:-8080}"
        ;;
    "install")
        do_install "$2"
        ;;
    "backup")
        do_backup "$2"
        ;;
    "version"|"-v"|"--version")
        echo "p-o-i-v-o-n versão ${AGENT_VERSION:-1.2.0-beta}"
        echo "PVN S¥STEM | AGENTE POIVON | skill yb POIVON | ${AGENT_CHANNEL:-Beta}"
        ;;
    "criar")
        # v2.0: integração LLM real (Issue #15)
        LLM_CLIENT="$PVN_LIBDIR/scripts/llm_client.sh"
        shift
        bash "$LLM_CLIENT" criar "$*"
        ;;
    "ai"|"perguntar")
        LLM_CLIENT="$PVN_LIBDIR/scripts/llm_client.sh"
        shift
        bash "$LLM_CLIENT" ask "$*"
        ;;
    "firebase")
        # v2.0: agente Firebase real (Issue #16)
        shift
        bash "$PVN_LIBDIR/agents/firebase_agent.sh" "$@"
        ;;
    "editar"|"corrigir"|"revisar"|"refatorar")
        # v2.0.0: engenharia REAL via LLM (fim dos stubs)
        LLM_CLIENT="$PVN_LIBDIR/scripts/llm_client.sh"
        tarefa="$1"; shift
        echo ""
        echo "┌──────────────────────────────────────────────────┐"
        echo "│   •[ P-O-I-V-O-N ]  //\\\\  pensando.....•      │"
        echo "└──────────────────────────────────────────────────┘"
        bash "$LLM_CLIENT" ask "[TAREFA: $tarefa — Regra 10 escopo mínimo] $*"
        ;;
    "guia")
        LLM_CLIENT="$PVN_LIBDIR/scripts/llm_client.sh"
        shift
        bash "$LLM_CLIENT" ask "[TAREFA: guia passo a passo, executável no Termux] $*"
        ;;
    "guias")
        echo ""
        echo "[GUIAS] Temas prontos: servidor | backup | python | node | git | firebase | storage"
        echo "[GUIAS] Use: pvn guia <tema>   (gera passo a passo via agente)"
        ;;
    "chave")
        do_chave || exit 1
        ;;
    "+mm")
        do_mm_memory "$2" "$3" || exit 1
        ;;
    *)
        echo "[ERRO] Comando desconhecido: $1"
        echo "[INFO] Digite 'pvn help' para ver os comandos disponíveis."
        exit 1
        ;;
esac

exit 0
