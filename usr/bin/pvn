#!/data/data/com.termux/files/usr/bin/bash
# ─────────────────────────────────────────────────────
# POIVON - Binário Principal
# PVN S¥STEM | AGENTE POIVON | skill yb POIVON
# Stable Edition — canal via AGENT_CHANNEL
# Version: v2.0.0
# ─────────────────────────────────────────────────────

PVN_PREFIX="$PREFIX"
PVN_CONFIG="${PVN_CONFIG:-$PREFIX/etc/p-o-i-v-o-n/pvn.conf}"
PVN_AGENTS="$PVN_PREFIX/lib/p-o-i-v-o-n/agents"
PVN_SCRIPTS="$PVN_PREFIX/lib/p-o-i-v-o-n/scripts"
PVN_DOCS="$PVN_PREFIX/share/p-o-i-v-o-n/docs"
PVN_TEMPLATES="$PVN_PREFIX/share/p-o-i-v-o-n/templates"
WORK_DIR="$HOME/storage/shared/POIVON"

# Carregar configuração
if [ -f "$PVN_CONFIG" ]; then
    source "$PVN_CONFIG"
fi

# Verificar diretório de trabalho
if [ ! -d "$WORK_DIR" ]; then
    mkdir -p "$WORK_DIR/projects" "$WORK_DIR/scripts" "$WORK_DIR/data" "$WORK_DIR/backups" "$WORK_DIR/logs" "$WORK_DIR/guides"
fi

