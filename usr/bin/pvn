#!/data/data/com.termux/files/usr/bin/bash
# ─────────────────────────────────────────────────────
# POIVON - Binário Principal
# PVN S¥STEM | AGENTE POIVON | skill yb
# Termux Edition
# ─────────────────────────────────────────────────────

PVN_PREFIX="$PREFIX"
PVN_CONFIG="$PVN_PREFIX/etc/p-o-i-v-o-n/pvn.conf"
PVN_AGENTS="$PVN_PREFIX/lib/p-o-i-v-o-n/agents"
PVN_SCRIPTS="$PVN_PREFIX/lib/p-o-i-v-o-n/scripts"
PVN_DOCS="$PVN_PREFIX/share/p-o-i-v-o-n/docs"
PVN_TEMPLATES="$PVN_PREFIX/share/p-o-i-v-o-n/templates"
WORK_DIR="$HOME/storage/shared/POIVON"

# Carregar configuração
if [ -f "$PVN_CONFIG" ]; then
    source "$PVN_CONFIG"
fi

# Verificar diretório de trabalho
if [ ! -d "$WORK_DIR" ]; then
    mkdir -p "$WORK_DIR/projects" "$WORK_DIR/scripts" "$WORK_DIR/data" "$WORK_DIR/backups"
fi

# Splash Screen
